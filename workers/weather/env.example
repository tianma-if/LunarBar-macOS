# LunarBar Weather Worker environment example
#
# Copy this file to a local/private environment file if you need notes while
# deploying. Do not commit real secret values.

# Cloudflare Worker name. This is configured in wrangler.jsonc.
WORKER_NAME=lunarbar-weather

# Cloudflare KV namespace binding name. The Worker source reads env.WEATHER_CACHE.
# This must match the `binding` value in wrangler.jsonc.
WEATHER_CACHE_BINDING=WEATHER_CACHE

# Cloudflare KV namespace ID for weather cache.
# This is not a secret, but it is account-specific.
WEATHER_CACHE_NAMESPACE_ID=replace-with-cloudflare-kv-namespace-id

# QWeather JWT credential ID.
# In the QWeather console this is shown as "凭据ID".
# Store in Cloudflare as a secret:
#   wrangler secret put QWEATHER_CREDENTIAL_ID
QWEATHER_CREDENTIAL_ID=replace-with-qweather-credential-id

# QWeather project ID.
# In the QWeather console this is shown in project details, not credential details.
# Store in Cloudflare as a secret:
#   wrangler secret put QWEATHER_PROJECT_ID
QWEATHER_PROJECT_ID=replace-with-qweather-project-id

# QWeather Ed25519 private key in PEM format.
# This is highly sensitive. Never commit the real value to GitHub.
# Store in Cloudflare as a secret:
#   wrangler secret put QWEATHER_PRIVATE_KEY
QWEATHER_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# QWeather API host for JWT authentication.
# New QWeather JWT credentials may require the project-specific API Host from
# the QWeather console. The default public host may return HTTP 403.
# Configure in wrangler.jsonc vars or store as a secret:
#   wrangler secret put QWEATHER_API_HOST
QWEATHER_API_HOST=https://devapi.qweather.com

# Fresh cache TTL in seconds. Default: 1800 seconds, or 30 minutes.
CACHE_TTL_SECONDS=1800

# Stale cache TTL in seconds. If upstream weather fails, stale data can be
# returned during this window. Default: 21600 seconds, or 6 hours.
STALE_TTL_SECONDS=21600
